DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
# Optional direct Neon URL for migrations. If empty, migrations use DATABASE_URL.
DIRECT_URL=""
PRISMA_TRANSIENT_RETRIES="2"

ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="replace-this"
JWT_SECRET="replace-with-long-random-secret"
ENCRYPTION_KEY=""
CRON_SECRET="replace-with-long-random-secret"

SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""
SPOTIFY_REDIRECT_URI="https://your-domain.example/api/oauth/spotify/callback"
# Empty SPOTIFY_SCOPES lets the flags below build the scope list.
SPOTIFY_SCOPES=""
SPOTIFY_ENABLE_PLAYLIST_SCOPES="true"
SPOTIFY_ENABLE_WRITE_SCOPES="true"

YOUTUBE_BROWSER_AUTOMATION="true"
SOUNDCLOUD_BROWSER_AUTOMATION="true"
# Use "state" in GitHub Actions. Use "profile" on a VM with a persistent Chrome profile.
WORKER_BROWSER="state"
HEADLESS="true"
CDP_URL_YOUTUBE="http://browser-youtube:9222"
CDP_URL_SOUNDCLOUD="http://browser-soundcloud:9222"
WORKER_CHECK_LIVE="false"

YOUTUBE_STATE_GZIP_BASE64=""
SOUNDCLOUD_STATE_GZIP_BASE64=""
YOUTUBE_STATE_JSON_BASE64=""
SOUNDCLOUD_STATE_JSON_BASE64=""
