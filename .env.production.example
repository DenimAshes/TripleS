DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
PRISMA_TRANSIENT_RETRIES="2"

ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="replace-this"
JWT_SECRET="replace-with-long-random-secret"
ENCRYPTION_KEY=""
CRON_SECRET="replace-with-long-random-secret"

SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""
SPOTIFY_REDIRECT_URI="https://YOUR_DOMAIN/api/oauth/spotify/callback"
SPOTIFY_SCOPES="user-read-private user-read-email playlist-read-private playlist-read-collaborative playlist-modify-private playlist-modify-public"
SPOTIFY_ENABLE_PLAYLIST_SCOPES="true"
SPOTIFY_ENABLE_WRITE_SCOPES="true"

YOUTUBE_BROWSER_AUTOMATION="true"
SOUNDCLOUD_BROWSER_AUTOMATION="true"
WORKER_BROWSER="state"
HEADLESS="true"

YOUTUBE_STATE_JSON_BASE64=""
SOUNDCLOUD_STATE_JSON_BASE64=""
