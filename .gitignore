# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.production.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# playwright worker session state (cookies)
/worker/state/*.json
/worker/state/*.tmp
/worker/state/*.html
/worker/state/*.png
/worker/state/*.log
!/worker/state/.gitkeep
/worker/chrome-profile/
/worker/cloak-profile/

# local browser verification artifacts
/.playwright-mcp/

# local agent worktrees; Claude/Codex can use them, but the main project
# should not commit or test these transient workspaces.
/.claude/
