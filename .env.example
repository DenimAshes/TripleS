# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
# Optional direct Neon URL for migrations. If empty, migrations use DATABASE_URL.
DIRECT_URL=""
PRISMA_TRANSIENT_RETRIES="2"

# Auth
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="changeme"
JWT_SECRET="your-jwt-secret-here"

# Token encryption (32 bytes hex)
ENCRYPTION_KEY=""

# Spotify (optional; empty means mock mode)
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""
SPOTIFY_REDIRECT_URI="http://127.0.0.1:3000/api/oauth/spotify/callback"
# Keep minimal for first login. Remove SPOTIFY_SCOPES later to enable playlist read scopes.
SPOTIFY_SCOPES="user-read-private user-read-email"
SPOTIFY_ENABLE_PLAYLIST_SCOPES="false"
# Keep false for first login. Set true later if Spotify should be a destination.
SPOTIFY_ENABLE_WRITE_SCOPES="false"

# YouTube Music browser automation (no YouTube Data API)
# Run: npm run chrome && npm run login -- youtube cdp
YOUTUBE_BROWSER_AUTOMATION="false"
# state = saved cookies JSON; profile = persistent Chrome profile for trusted local/VM runs.
WORKER_BROWSER="state"
HEADLESS="true"
YOUTUBE_STATE_GZIP_BASE64=""
YOUTUBE_STATE_JSON_BASE64=""

# SoundCloud (optional)
SOUNDCLOUD_CLIENT_ID=""
SOUNDCLOUD_CLIENT_SECRET=""
SOUNDCLOUD_REDIRECT_URI="http://localhost:3000/api/oauth/soundcloud/callback"
# SoundCloud browser automation
# Run: npm run chrome -- soundcloud && npm run login -- soundcloud cdp
SOUNDCLOUD_BROWSER_AUTOMATION="false"
SOUNDCLOUD_STATE_GZIP_BASE64=""
SOUNDCLOUD_STATE_JSON_BASE64=""

# Cron protection
CRON_SECRET=""
